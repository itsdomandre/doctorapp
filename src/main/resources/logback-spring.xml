<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="LOG_FILE"     source="logging.file.name"     defaultValue="/var/log/doctor-app.log"/>
    <springProperty scope="context" name="LOG_MAX_SIZE" source="logging.file.max-size"  defaultValue="10MB"/>

    <!-- ─── DEV: console com cores + arquivo legível ─── -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%yellow(%X{requestId:-?})] [%cyan(%X{userEmail:-anon})] [%X{clientIp:-?}] %magenta(%logger{30}) - %msg%n</pattern>
            </encoder>
        </appender>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>${LOG_MAX_SIZE}</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{requestId:-?}] [%X{userEmail:-anon}] [%X{clientIp:-?}] %logger{30} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- ─── PROD: arquivo estruturado pipe-delimited para parsers/SIEM ─── -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>${LOG_MAX_SIZE}</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <!-- timestamp|level|requestId|userEmail|clientIp|logger|message -->
                <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}|%-5level|%X{requestId:-}|%X{userEmail:-anonymous}|%X{clientIp:-}|%logger{30}|%replace(%msg){'[\r\n\|]',' '}%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
</configuration>
